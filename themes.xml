<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FXCam" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/surface</item>
        <item name="colorOnPrimary">@android:color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.FXCam.ActionBar" parent="Theme.FXCam">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="actionBarStyle">@style/FXCamActionBar</item>
    </style>

    <style name="FXCamActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/surface</item>
        <item name="titleTextStyle">@style/FXCamActionBarTitle</item>
    </style>

    <style name="FXCamActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
